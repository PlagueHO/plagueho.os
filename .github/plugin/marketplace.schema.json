{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Plugin Marketplace",
  "description": "Schema for a VS Code agent plugin marketplace index.",
  "type": "object",
  "required": ["name", "metadata", "owner", "plugins"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Marketplace identifier."
    },
    "metadata": {
      "type": "object",
      "required": ["description", "version"],
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        }
      }
    },
    "owner": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "source", "description", "version"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "Plugin identifier (lowercase, hyphens allowed)."
          },
          "source": {
            "type": "string",
            "minLength": 1,
            "description": "Relative path to the plugin directory."
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "skills": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "agents": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "hooks": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
